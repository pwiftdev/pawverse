# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# Comma-separated browser origins allowed to open game WebSockets in production.
# Leave empty during local development. Do not include paths or a trailing slash.
# Example: https://pawverse.vercel.app,https://play.pawverse.com
ALLOWED_ORIGINS=

# ─── Client (exposed to the browser, must be prefixed VITE_) ─────────────────
# Solana cluster: devnet | testnet | mainnet-beta
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC=https://api.devnet.solana.com

# Premium content gate: an SPL token mint OR NFT collection address.
# Wallets holding any amount of this mint unlock premium breeds/cosmetics.
# Leave empty to disable gating (everything unlocked).
VITE_PREMIUM_MINT=

# Optional override for the game WebSocket endpoint.
# Default: same origin as the page, path /ws (proxied by Vite in dev).
# Example for a split deploy: wss://pawverse-server.herokuapp.com/ws
VITE_WS_URL=
